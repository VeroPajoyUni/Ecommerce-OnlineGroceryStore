<?php
/**
 * Vista Admin — Listado de Pagos
 * Ruta: View/admin/payments/PaymentIndexView.phtml
 */
?>

<div class="page-enter">

    <div class="mb-4">
        <h2><i class="bi bi-credit-card"></i> Pagos</h2>
        <p class="text-muted">Historial de pagos registrados en el sistema.</p>
    </div>

    <?php if(empty($payments)): ?>
        <div class="text-center py-5">
            <i class="bi bi-credit-card fs-1 text-muted"></i>
            <p class="text-muted mt-2">No hay pagos registrados aún.</p>
        </div>
    <?php else: ?>

    <div class="table-responsive">
        <table class="table table-hover admin-table align-middle">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Orden</th>
                    <th>Total Orden</th>
                    <th>Método</th>
                    <th>Estado</th>
                    <th>Fecha</th>
                </tr>
            </thead>
            <tbody>
                <?php foreach($payments as $payment): ?>
                <tr>
                    <td><?= $payment['id'] ?></td>
                    <td><strong>#<?= $payment['order_id'] ?></strong></td>
                    <td>$<?= number_format($payment['total_orden'] ?? 0, 0, ',', '.') ?></td>
                    <td>
                        <?php
                        $iconMetodo = match($payment['metodo'] ?? '') {
                            'efectivo'      => 'bi-cash',
                            'transferencia' => 'bi-bank',
                            'nequi'         => 'bi-phone',
                            default         => 'bi-credit-card'
                        };
                        ?>
                        <i class="bi <?= $iconMetodo ?>"></i>
                        <?= ucfirst($payment['metodo'] ?? '—') ?>
                    </td>
                    <td>
                        <span class="badge <?= $payment['estado'] === 'pagado' ? 'bg-success' : 'bg-warning text-dark' ?>">
                            <?= ucfirst($payment['estado'] ?? '—') ?>
                        </span>
                    </td>
                    <td>
                        <small class="text-muted">
                            <?= date('d/m/Y H:i', strtotime($payment['fecha'])) ?>
                        </small>
                    </td>
                </tr>
                <?php endforeach; ?>
            </tbody>
        </table>
    </div>

    <?php endif; ?>
</div>